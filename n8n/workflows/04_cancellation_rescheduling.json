      "parameters": {
        "jsCode": "const data = $('Determinar etapa').first().json;\nconst userInput = (data.messageText || '').trim();\n\nlet selectedAppointment = null;\ntry {\n  const msgs = typeof data.messages === 'string' ? JSON.parse(data.messages) : (data.messages || []);\n  for (const m of msgs) {\n    if (m.selected_appointment) {\n      selectedAppointment = typeof m.selected_appointment === 'string' ? JSON.parse(m.selected_appointment) : m.selected_appointment;\n    }\n  }\n} catch(e) {}\n\nconst wantsCancel = userInput === '1';\n\nreturn [{\n  json: {\n    ...data,\n    wantsCancel,\n    selectedAppointment,\n    cancellation_reason_raw: userInput,\n    cancellation_category: 'other',\n    ai_summary: 'Cancelamento direto'\n  }\n}];"
