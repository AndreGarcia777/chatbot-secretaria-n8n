    {
      "parameters": {
        "jsCode": "const data = $('Determinar etapa').first().json;\nconst userInput = (data.messageText || '').trim();\n\nif (userInput === '0') {\n  return [{ json: { ...data, wantsExit: true, validChoice: false, selectedAppointment: null, rePromptText: '' } }];\n}\n\nconst choice = parseInt(userInput);\nlet appointments = [];\ntry {\n  const msgs = typeof data.messages === 'string' ? JSON.parse(data.messages) : (data.messages || []);\n  for (const m of msgs) {\n    if (m.appointments) {\n      appointments = typeof m.appointments === 'string' ? JSON.parse(m.appointments) : m.appointments;\n    }\n  }\n} catch(e) {}\n\nconst selectedAppt = appointments[choice - 1] || null;\n\nlet rePromptText = '';\nif (!selectedAppt) {\n  rePromptText = '⚠️ Não entendi. Por favor, envie apenas o *número* da consulta:\\n\\n';\n  appointments.forEach((a, i) => {\n    const date = new Date(a.scheduled_at);\n    const dateStr = date.toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: '2-digit' });\n    const timeStr = date.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });\n    rePromptText += `${i+1}️⃣ ${dateStr} às ${timeStr} — ${a.doctor_name}\\n`;\n  });\n  rePromptText += '\\nDigite o *número* desejado.';\n}\n\nreturn [{\n  json: {\n    ...data,\n    wantsExit: false,\n    selectedAppointment: selectedAppt,\n    validChoice: selectedAppt !== null,\n    rePromptText\n  }\n}];"
      },
      "id": "604045d8-ae83-48e6-a7e8-b2873790330a",
      "name": "Identificar consulta escolhida",
