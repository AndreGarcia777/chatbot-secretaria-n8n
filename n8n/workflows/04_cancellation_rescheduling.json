    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst state = data.conversation_state;\n\nlet action = 'LIST_APPOINTMENTS';\nswitch(state) {\n  case 'CANCELLATION_SELECT': action = 'LIST_APPOINTMENTS'; break;\n  case 'CANCELLATION_CONFIRM': action = 'COLLECT_REASON'; break;\n  case 'CANCELLATION_EXECUTE': action = 'HANDLE_RESCHEDULE_RESPONSE'; break;\n  default: action = 'LIST_APPOINTMENTS';\n}\n\nreturn [{ json: { ...data, action } }];"
      },
      "id": "eaa92672-e3a6-48c0-a90e-72ffd8e8052d",
