    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT a.id, a.scheduled_at, d.name as doctor_name, d.specialty\nFROM public.appointments a\nJOIN public.doctors d ON a.doctor_id = d.id\nWHERE a.clinic_id = $1\n  AND a.patient_id = $2\n  AND a.scheduled_at > NOW()\n  AND a.status = 'scheduled'\nORDER BY a.scheduled_at;",
        "options": {
          "queryReplacement": "{{ $json.clinic_id }}, {{ $json.patient_id }}"
        }
      },
      "id": "f01bde1a-b7db-449f-bef2-874faa917fe5",
      "name": "Listar consultas futuras",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        3248,
        496
      ],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "hC1ecti2DctPVZwU",
          "name": "Supabase account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const data = $('Determinar etapa').first().json;\nconst appointments = $input.all().map(item => item.json);\n\nif (appointments.length === 0 || !appointments[0].id) {\n  return [{\n    json: {\n      ...data,\n      hasAppointments: false,\n      responseText: 'Você não tem consultas futuras agendadas. 📋\\n\\nDeseja agendar uma nova consulta?\\n\\n1️⃣ Agendar consulta\\n2️⃣ Voltar ao menu',\n      newState: 'MENU'\n    }\n  }];\n}\n\nlet text = '📋 *Suas consultas agendadas:*\\n\\n';\nappointments.forEach((a, i) => {\n  const date = new Date(a.scheduled_at);\n  const dateStr = date.toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: '2-digit', year: 'numeric' });\n  const timeStr = date.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });\n  text += `${i + 1}️⃣ ${dateStr} às ${timeStr} — ${a.doctor_name} (${a.specialty})\\n`;\n});\ntext += '\\nDigite o *número* da consulta que deseja cancelar ou remarcar.';\n\nreturn [{\n  json: {\n    ...data,\n    hasAppointments: true,\n    appointmentsList: appointments,\n    responseText: text,\n    newState: 'CANCELLATION_CONFIRM'\n  }\n}];"
      },
      "id": "a1ce839d-afed-4d44-8575-d155123d1152",
      "name": "Formatar consultas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3456,
        496
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE public.conversations\nSET state = $1,\n    messages = messages || jsonb_build_array(jsonb_build_object('appointments', $2::text)),\n    updated_at = NOW()\nWHERE clinic_id = $3\n  AND patient_id = $4;",
        "options": {
          "queryReplacement": "{{ $json.newState }}, {{ JSON.stringify($json.appointmentsList || []) }}, {{ $json.clinic_id }}, {{ $json.patient_id }}"
        }
      },
      "id": "56d2a202-4423-4e90-ba94-e45d3406a084",
      "name": "Atualizar estado (consultas)",
