    {
      "parameters": {
        "jsCode": "// Coleta CPF last4 e cria o paciente\nconst data = $input.first().json;\nconst cpfLast4 = data.messageText.trim().replace(/\\D/g, '');\n\nif (cpfLast4.length !== 4) {\n  return [{\n    json: {\n      ...data,\n      validCpf: false,\n      errorMsg: 'Por favor, envie exatamente os *4 últimos dígitos* do seu CPF (apenas números).'\n    }\n  }];\n}\n\n// Recupera dados coletados da conversa\nlet collectedName = '';\nlet collectedInsurance = '';\ntry {\n  const msgs = typeof data.messages === 'string' ? JSON.parse(data.messages) : (data.messages || []);\n  for (const m of msgs) {\n    if (m.collected_name) collectedName = m.collected_name;\n    if (m.collected_insurance) collectedInsurance = m.collected_insurance;\n  }\n} catch(e) {}\n\nreturn [{\n  json: {\n    ...data,\n    validCpf: true,\n    cpf_last4: cpfLast4,\n    collected_name: collectedName,\n    collected_insurance: collectedInsurance\n  }\n}];"
      },
      "id": "6517ad3d-dda3-4d34-a01a-c62b40089203",
      "name": "Validar CPF e recuperar dados",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
