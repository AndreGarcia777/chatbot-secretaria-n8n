    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Remove conversa temporária usando whatsapp_number\nDELETE FROM public.conversations\nWHERE clinic_id = $1\n  AND whatsapp_number = $2\n  AND patient_id IS NULL;\n\n-- Upsert conversa do paciente (cria ou reseta se já existir)\nINSERT INTO public.conversations (clinic_id, patient_id, whatsapp_number, state, messages, updated_at)\nVALUES (\n  $3::uuid,\n  $4::uuid,\n  $5,\n  'MENU',\n  '[]'::jsonb,\n  NOW()\n)\nON CONFLICT (clinic_id, patient_id)\nDO UPDATE SET state = 'MENU', messages = '[]'::jsonb, updated_at = NOW()\nRETURNING id, patient_id, state;",
        "options": {
          "queryReplacement": "{{ $('Trigger do workflow principal').first().json.clinic_id }}, {{ $('Trigger do workflow principal').first().json.fromNumber }}, {{ $('Trigger do workflow principal').first().json.clinic_id }}, {{ $json.id }}, {{ $('Trigger do workflow principal').first().json.fromNumber }}"
        }
