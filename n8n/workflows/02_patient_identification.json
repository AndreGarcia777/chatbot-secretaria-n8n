      "id": "7fcef299-4abe-4ed3-b8a8-49d62cd04aa8",
      "name": "Switch ação",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        1888,
        960
      ]
    },
    {
      "parameters": {
        "jsCode": "// Recebe dados do workflow principal\nconst data = $input.first().json;\nconst state = data.conversation_state;\nconst messageText = (data.messageText || '').trim();\nconst messageTextLower = messageText.toLowerCase();\n// Remove pontuação (ex: 'Novo!' → 'novo')\nconst messageClean = messageTextLower.replace(/[^\\w\\sàáâãéêíóôõúçÀÁÂÃÉÊÍÓÔÕÚÇ]/gi, '').trim();\n\nlet action = 'unknown';\nlet cleanedInput = messageText;\nlet invalidMessage = '';\n\nif (state === 'IDENTIFICATION_ASK') {\n  const newPatientKeywords = ['novo', 'nova', 'nao', 'não', 'primeira vez', 'new'];\n\n  if (newPatientKeywords.includes(messageClean)) {\n    action = 'NEW_PATIENT';\n  } else {\n    const digitsOnly = messageTextLower.replace(/\\D/g, '');\n    const isCpfLast4 = /^\\d{3}-?\\d{1}$/.test(messageText.trim()) || /^\\d{4}$/.test(digitsOnly);\n    const isDate = /^\\d{2}\\/\\d{2}\\/\\d{4}$/.test(messageText.trim()) || /^\\d{8}$/.test(digitsOnly);\n\n    if (isCpfLast4 && digitsOnly.length === 4) {\n      action = 'VERIFY_IDENTITY';\n      cleanedInput = digitsOnly;\n    } else if (isDate) {\n      action = 'VERIFY_IDENTITY';\n      cleanedInput = messageText.trim();\n    } else {\n      action = 'INVALID_INPUT';\n      invalidMessage = 'Não entendi sua resposta. 🤔\\n\\nPor favor, envie:\\n\\n✅ Os *4 últimos dígitos* do seu CPF (ex: 1234)\\n✅ Sua *data de nascimento* (ex: 15/03/1985)\\n🆕 Ou digite *novo* se é sua primeira vez';\n    }\n  }\n} else if (state === 'IDENTIFICATION_COLLECT_NAME') {\n  // Nome deve ter pelo menos 2 letras\n  const hasLetters = /[a-zA-ZàáâãéêíóôõúçÀÁÂÃÉÊÍÓÔÕÚÇ]{2,}/.test(messageText);\n  if (hasLetters && messageText.length >= 2) {\n    action = 'COLLECT_NAME';\n  } else {\n    action = 'INVALID_INPUT';\n    invalidMessage = 'Por favor, digite seu *nome completo* (ex: Maria da Silva). 📝';\n  }\n} else if (state === 'IDENTIFICATION_COLLECT_INSURANCE') {\n  // Convênio deve ter pelo menos 2 caracteres com letras\n  const hasLetters = /[a-zA-ZàáâãéêíóôõúçÀÁÂÃÉÊÍÓÔÕÚÇ]/.test(messageText);\n  if (hasLetters && messageText.length >= 2) {\n    action = 'COLLECT_INSURANCE';\n  } else {\n    action = 'INVALID_INPUT';\n    invalidMessage = 'Por favor, informe o nome do seu *convênio* (ex: Unimed, SulAmérica) ou digite *particular* se não tiver. 🏥';\n  }\n} else if (state === 'IDENTIFICATION_COLLECT_CPF') {\n  action = 'COLLECT_CPF';\n}\n\nreturn [{\n  json: {\n    ...data,\n    action,\n    cleanedInput,\n    invalidMessage\n  }\n}];"
      },
